{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deadlock Mod Merger",
  "version": "2.0.0",
  "identifier": "dev.phlgmy.deadlock-mod-merger",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Deadlock Mod Merger",
        "width": 760,
        "height": 720,
        "minWidth": 560,
        "minHeight": 520,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
